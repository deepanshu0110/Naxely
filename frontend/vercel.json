{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "SAMEORIGIN",
        "X-XSS-Protection": "1; mode=block",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://*.supabase.co https://api.naxely.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self';",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()",
        "Content-Language": "en"
      },
      "continue": true
    },
    { "source": "/pricing", "destination": "/pricing/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/terms", "destination": "/terms/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/refund", "destination": "/refund/index.html" },
    { "source": "/login", "destination": "/login/index.html" },
    { "source": "/signup", "destination": "/signup/index.html" },
    { "source": "/auth", "destination": "/shell.html" },
    { "source": "/auth/:path*", "destination": "/shell.html" },
    { "source": "/dashboard", "destination": "/shell.html" },
    { "source": "/dashboard/:path*", "destination": "/shell.html" },
    { "source": "/report", "destination": "/shell.html" },
    { "source": "/report/:path*", "destination": "/shell.html" },
    { "source": "/scheduled-reports", "destination": "/shell.html" },
    { "source": "/scheduled-reports/:path*", "destination": "/shell.html" },
    { "source": "/settings", "destination": "/shell.html" },
    { "source": "/settings/:path*", "destination": "/shell.html" },
    { "source": "/share", "destination": "/shell.html" },
    { "source": "/share/:path*", "destination": "/shell.html" },
    { "handle": "filesystem" },
    { "source": "/(.*)", "destination": "/shell.html", "status": 404 }
  ]
}
