{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "source": "/pricing", "destination": "/pricing/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/terms", "destination": "/terms/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/refund", "destination": "/refund/index.html" },
    { "source": "/login", "destination": "/login/index.html" },
    { "source": "/signup", "destination": "/signup/index.html" },
    { "source": "/auth/:path*", "destination": "/shell.html" },
    { "source": "/dashboard/:path*", "destination": "/shell.html" },
    { "source": "/report/:path*", "destination": "/shell.html" },
    { "source": "/scheduled-reports/:path*", "destination": "/shell.html" },
    { "source": "/settings/:path*", "destination": "/shell.html" },
    { "source": "/share/:path*", "destination": "/shell.html" },
    { "handle": "filesystem" },
    { "source": "/(.*)", "destination": "/shell.html", "status": 404 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://*.supabase.co https://api.naxely.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()" },
        { "key": "Content-Language", "value": "en" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(robots.txt|llms.txt|sitemap.xml)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
